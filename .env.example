# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=crowdvision

# Model Paths
YOLO_MODEL_PATH=models/yolov8n.pt
CSRNET_MODEL_PATH=models/csrnet_density.pth
REID_MODEL_PATH=models/reid_resnet50.pth
ANOMALY_MODEL_PATH=models/anomaly_detector.pth
FORECASTING_MODEL_PATH=models/gcn_gru.pth

# Vector Database
CHROMA_DB_PATH=./chroma_db
FAISS_INDEX_PATH=./data/faiss_index

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Inference Configuration
DEVICE=cuda  # cuda or cpu
BATCH_SIZE=8
CONFIDENCE_THRESHOLD=0.5

# Alert Thresholds
DENSITY_ALERT_THRESHOLD=0.8
BOTTLENECK_THRESHOLD=0.8
ANOMALY_CONFIDENCE_THRESHOLD=0.7
